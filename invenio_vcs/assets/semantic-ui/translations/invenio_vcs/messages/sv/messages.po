msgid ""
"Repository sync started in the background. Please reload the page in about a "
"minute."
msgstr ""
"Synkronisering av repositoriet har startats i bakgrunden. Ladda om sidan om "
"ungefär en minut."

msgid "The repository sync failed (status {{status}}). Please try again later."
msgstr ""
"Synkroniseringen av repositoriet misslyckades (status {{status}}). Försök igen "
"senare."

msgid ""
"This action seems to take some time, refresh the page after several minutes to "
"inspect the synchronisation."
msgstr ""
"Den här åtgärden verkar ta lite tid. Uppdatera sidan efter några minuter för "
"att kontrollera synkroniseringen."

msgid "There has been a problem: {{error}}"
msgstr "Ett problem har uppstått: {{error}}"

msgid "Repository enabled successfully. Please reload the page."
msgstr "Repositoriet har aktiverats. Ladda om sidan."

msgid "Failed to update repository (status {{status}}). Please try again later."
msgstr ""
"Det gick inte att uppdatera repositoriet (status {{status}}). Försök igen "
"senare."
