#: invenio_vcs/errors.py:17
msgid "The user cannot access this repository"
msgstr "Användaren kan inte komma åt detta repository"

#: invenio_vcs/errors.py:31
msgid "This repository is not enabled for webhooks."
msgstr "Detta repository är inte aktiverat för webhooks."

#: invenio_vcs/errors.py:42
msgid "The repository does not exist."
msgstr "Repositoryt finns inte."

#: invenio_vcs/errors.py:53
msgid "Invalid sender for event"
