#: invenio_vcs/errors.py:65
msgid "The release has already been received."
msgstr "Releasen har redan tagits emot."

#: invenio_vcs/errors.py:90
msgid "The OAuth session token was not found."
msgstr "OAuth-sessionstoken hittades inte."

#: invenio_vcs/errors.py:101
msgid "RemoteAccount not found for user"
msgstr "RemoteAccount hittades inte för användaren"

#: invenio_vcs/errors.py:112
msgid "RemoteAccount extra data not set for user."
msgstr "Extra data för RemoteAccount har inte angetts för användaren."

#: invenio_vcs/errors.py:123
msgid "Release does not exist."
msgstr "Releasen finns inte."

#: invenio_vcs/errors.py:133
msgid "Provider API returned an unexpected error."
msgstr "Leverantörens API returnerade ett oväntat fel."

#: invenio_vcs/errors.py:143
msgid "Error fetching release zipball file."
msgstr "Fel vid hämtning av zipball-fil för release."

#: invenio_vcs/errors.py:153
msgid "Provider did not return user profile information."
msgstr "Leverantören returnerade ingen användarprofilinformation."

#: invenio_vcs/errors.py:167
msgid "Multiple existing webhooks found."
msgstr "Flera befintliga webhooks hittades."

#: invenio_vcs/ext.py:98
#, python-format
msgid "%(icon)s %(provider)s"
msgstr "%(icon)s %(provider)s"

#: invenio_vcs/jobs.py:28
msgid "The name of the locally configured provider to sync accounts for. If not specified, will use the first entry in the list of configured providers."
msgstr "Namnet på den lokalt konfigurerade leverantören som konton ska synkroniseras för. Om inget anges används den första posten i listan över konfigurerade leverantörer."

#: invenio_vcs/jobs.py:39
msgid "The maximum number of accounts to sync in one run. Running the job multiple times will make it continue handling further accounts. The default value is 1000. Specifying 0 removes the limit."
msgstr "Det maximala antalet konton att synkronisera i en körning. Om jobbet körs flera gånger fortsätter det att hantera ytterligare konton. Standardvärdet är 1000. Om 0 anges tas gränsen bort."

#: invenio_vcs/jobs.py:50
msgid "The minimum time (in seconds) that needs to have elapsed since the last sync for an account to be included in the list of accounts to sync. The default value is 30 days (2592000 seconds). Using 0 will cause all accounts to be considered."
msgstr "Den minsta tid (i sekunder) som måste ha förflutit sedan den senaste synkroniseringen för att ett konto ska inkluderas i listan över konton att synkronisera. Standardvärdet är 30 dagar (2592000 sekunder). Om 0 används beaktas alla konton."

#: invenio_vcs/jobs.py:71
msgid "No VCS providers configured on the instance."
msgstr "Inga VCS-leverantörer har konfigurerats på instansen."

#: invenio_vcs/jobs.py:80
#, python-format
msgid "Provider with ID %(value)s not registered on instance."
msgstr "Leverantör med ID %(value)s är inte registrerad på instansen."

#: invenio_vcs/jobs.py:88
msgid "Refresh VCS accounts"
msgstr "Uppdatera VCS-konton"

#: invenio_vcs/jobs.py:89
msgid "Refresh stale VCS accounts and re-sync their repository metadata"
msgstr "Uppdatera inaktuella VCS-konton och synkronisera deras repositorymetadata på nytt"

#: invenio_vcs/providers.py:288
msgid "Webhook data not found for user's token. Please disconnect and reconnect the account again."
msgstr "Webhook-data hittades inte för användarens token. Koppla från och återanslut kontot igen."

#: invenio_vcs/service.py:143
msgid "Last sync data is not set for user (remote data)."
msgstr "Data för senaste synkronisering har inte angetts för användaren (fjärrdata)."

#: invenio_vcs/service.py:374
msgid "Remote account was not found for user."
msgstr "Fjärrkontot hittades inte för användaren."

#: invenio_vcs/tasks.py:71
msgid "Deleted hook from vcs repository."
msgstr "Tog bort hook från VCS-repository."

